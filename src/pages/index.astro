---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
		<Header />
		<main>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
:root {
  --red:      #C8102E;
  --red-dk:   #9B0C22;
  --red-lt:   #FCEEF1;
  --navy:     #0D1B2A;
  --silver:   #F4F6F9;
  --muted:    #64748B;
  --border:   #E2E8F0;
  --text:     #111827;
  --white:    #FFFFFF;
  --r:        12px;
  --r-lg:     20px;
}
 
body {
  font-family: 'DM Sans', sans-serif;
  color: var(--text);
  background: #fff;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
}
 
.wrap {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 clamp(1.25rem, 5vw, 3rem);
}
 
.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: .9rem;
}
.eyebrow::before {
  content: '';
  display: block;
  width: 22px; height: 2px;
  background: var(--red);
  border-radius: 2px;
}
 
.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.9rem, 3.8vw, 2.85rem);
  font-weight: 900;
  line-height: 1.12;
  color: var(--navy);
  margin-bottom: 1.1rem;
}
 
.btn {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .78rem 1.7rem;
  border-radius: var(--r);
  font-size: .92rem; font-weight: 600; font-family: 'DM Sans', sans-serif;
  cursor: pointer; text-decoration: none; border: none;
  transition: transform .18s, box-shadow .18s, background .15s;
}
.btn:hover { transform: translateY(-2px); }
 
.btn-red  { background: var(--red); color: #fff; box-shadow: 0 4px 18px rgba(200,16,46,.35); }
.btn-red:hover  { background: var(--red-dk); box-shadow: 0 8px 28px rgba(200,16,46,.48); }
 
.btn-ghost { background: rgba(255,255,255,.1); color: #fff; border: 1.5px solid rgba(255,255,255,.28); }
.btn-ghost:hover { background: rgba(255,255,255,.16); border-color: rgba(255,255,255,.55); }
 
/* ── HERO ── */
#hero {
  background: var(--navy);
  position: relative; overflow: hidden;
  padding: clamp(4.5rem, 10vw, 8.5rem) 0 clamp(5rem, 12vw, 10rem);
}
#hero::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--red-dk) 0%, transparent 42%);
  opacity: .4; pointer-events: none;
}
 
.hero-grid {
  position: relative; z-index: 1;
  display: grid; grid-template-columns: 1.15fr 1fr;
  gap: 3rem; align-items: center;
}
@media (max-width: 780px) {
  .hero-grid { grid-template-columns: 1fr; }
  .hero-right { display: none; }
}
 
.hero-tag {
  font-size: .7rem; font-weight: 700; letter-spacing: .2em;
  text-transform: uppercase; color: var(--red);
  margin-bottom: 1.1rem;
  display: flex; align-items: center; gap: .6rem;
}
.hero-tag::before { content: ''; display: block; width: 28px; height: 2px; background: var(--red); }
 
#hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.6rem, 5.5vw, 4.2rem);
  font-weight: 900; line-height: 1.06; color: #fff;
  margin-bottom: 1.3rem;
}
#hero h1 em { font-style: normal; color: var(--red); }
 
.hero-desc { font-size: 1.05rem; color: rgba(255,255,255,.7); max-width: 500px; margin-bottom: 2rem; }
 
.hero-actions { display: flex; flex-wrap: wrap; gap: .9rem; }
 
.hero-right { display: flex; flex-direction: column; gap: 1rem; align-items: flex-end; }
 
.stat-card {
  background: rgba(255,255,255,.07);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,.11);
  border-radius: var(--r-lg);
  padding: 1.35rem 2.2rem; text-align: center; min-width: 210px;
}
.stat-card:nth-child(2) { margin-right: 2.5rem; }
 
.stat-num { font-family: 'Playfair Display', serif; font-size: 2.7rem; font-weight: 900; color: var(--red); line-height: 1; }
.stat-label { font-size: .76rem; color: rgba(255,255,255,.55); margin-top: .3rem; text-transform: uppercase; letter-spacing: .1em; }
 
.ecg-wave { position: absolute; bottom: 0; left: 0; right: 0; pointer-events: none; }
 
/* ── TRUST ── */
#trust { background: #fff; border-bottom: 1px solid var(--border); padding: 1.5rem 0; }
 
.trust-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 1.2rem 3rem; align-items: center; }
 
.trust-item { display: flex; align-items: center; gap: .55rem; font-size: .87rem; font-weight: 500; color: var(--muted); }
.trust-item svg { color: var(--red); flex-shrink: 0; width: 17px; height: 17px; }
 
/* ── ABOUT ── */
#about { background: var(--silver); padding: clamp(4rem, 9vw, 7rem) 0; }
 
.about-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 5vw, 5rem); align-items: center;
}
@media (max-width: 780px) { .about-grid { grid-template-columns: 1fr; } }
 
.check-list { list-style: none; display: flex; flex-direction: column; gap: .75rem; margin: 1.4rem 0 2.2rem; }
.check-list li { display: flex; align-items: flex-start; gap: .75rem; font-size: .95rem; }
.check-list svg { color: var(--red); flex-shrink: 0; margin-top: .18rem; width: 18px; height: 18px; }
 
.cert-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
 
.cert-card {
  background: #fff; border: 1px solid var(--border); border-radius: var(--r-lg);
  padding: 1.8rem 1.5rem; text-align: center;
  transition: transform .2s, box-shadow .2s;
}
.cert-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,0,0,.1); }
.cert-card.wide { grid-column: span 2; }
 
.cert-icon {
  width: 52px; height: 52px; border-radius: 50%;
  background: var(--red-lt); color: var(--red);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 1rem;
}
.cert-icon svg { width: 24px; height: 24px; }
.cert-card h3 { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: .3rem; }
.cert-card p { font-size: .8rem; color: var(--muted); line-height: 1.5; }
 
/* ── CLASSES ── */
#classes { background: #fff; padding: clamp(4rem, 9vw, 7rem) 0; }
 
.classes-head { text-align: center; max-width: 640px; margin: 0 auto 3.5rem; }
.classes-head .eyebrow { justify-content: center; }
.classes-head .eyebrow::before { display: none; }
.classes-head p { color: var(--muted); margin-top: .6rem; }
 
.cards-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.8rem; }
@media (max-width: 900px) { .cards-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; } }
 
.card {
  border-radius: var(--r-lg); border: 1px solid var(--border);
  overflow: hidden; display: flex; flex-direction: column; background: #fff;
  transition: transform .22s, box-shadow .22s;
}
.card:hover { transform: translateY(-7px); box-shadow: 0 18px 48px rgba(0,0,0,.12); }
 
.card-stripe { height: 5px; width: 100%; }
.card--bls  .card-stripe { background: linear-gradient(90deg,#C8102E,#E63652); }
.card--acls .card-stripe { background: linear-gradient(90deg,#0D1B2A,#1C3A5E); }
.card--pals .card-stripe { background: linear-gradient(90deg,#A06A10,#C98A1A); }
 
.card-body { padding: 2rem 1.8rem; flex: 1; display: flex; flex-direction: column; }
 
.card-icon { width: 54px; height: 54px; border-radius: var(--r); display: flex; align-items: center; justify-content: center; margin-bottom: 1.2rem; }
.card--bls  .card-icon { background: var(--red-lt); color: var(--red); }
.card--acls .card-icon { background: #E8EDF3; color: var(--navy); }
.card--pals .card-icon { background: #FEF3E2; color: #A06A10; }
.card-icon svg { width: 26px; height: 26px; }
 
.card-tag { font-size: .68rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; margin-bottom: .45rem; }
.card--bls  .card-tag { color: var(--red); }
.card--acls .card-tag { color: var(--navy); }
.card--pals .card-tag { color: #A06A10; }
 
.card-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 900; color: var(--navy); line-height: 1; margin-bottom: .25rem; }
.card-subtitle { font-size: .82rem; color: var(--muted); margin-bottom: 1rem; }
.card-desc { font-size: .9rem; color: #4B5563; line-height: 1.65; flex: 1; margin-bottom: 1.5rem; }
 
.pills { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 1.5rem; }
.pill {
  display: inline-flex; align-items: center; gap: .35rem;
  padding: .28rem .75rem; border-radius: 999px;
  font-size: .74rem; font-weight: 500;
  background: var(--silver); color: var(--text); border: 1px solid var(--border);
}
.pill svg { width: 11px; height: 11px; }
 
.card-foot {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.1rem 1.8rem;
  background: var(--silver); border-top: 1px solid var(--border);
}
 
.card-price { font-family: 'Playfair Display', serif; font-weight: 900; font-size: 1.05rem; color: var(--navy); }
.card-price span { display: block; font-family: 'DM Sans',sans-serif; font-size: .76rem; font-weight: 400; color: var(--muted); }
 
.card-btn {
  display: inline-flex; align-items: center; gap: .4rem;
  padding: .6rem 1.25rem; border-radius: var(--r);
  font-size: .84rem; font-weight: 600; font-family: 'DM Sans',sans-serif;
  cursor: pointer; text-decoration: none; border: none;
  transition: background .15s, transform .15s;
}
.card-btn:hover { transform: translateX(2px); }
.card--bls  .card-btn { background: var(--red); color: #fff; }
.card--acls .card-btn { background: var(--navy); color: #fff; }
.card--pals .card-btn { background: #A06A10; color: #fff; }
 
/* ── CTA ── */
#cta {
  background: var(--navy); padding: clamp(3.5rem,8vw,6.5rem) 0;
  position: relative; overflow: hidden;
}
#cta::after {
  content: ''; position: absolute;
  right: -80px; top: 50%; transform: translateY(-50%);
  width: 500px; height: 500px; border-radius: 50%;
  background: radial-gradient(circle, rgba(200,16,46,.22) 0%, transparent 68%);
  pointer-events: none;
}
 
.cta-inner {
  position: relative; z-index: 1;
  display: flex; flex-wrap: wrap;
  align-items: center; justify-content: space-between; gap: 2rem;
}
#cta h2 { font-family: 'Playfair Display',serif; font-size: clamp(1.9rem,3.8vw,2.8rem); font-weight: 900; color: #fff; margin-bottom: .5rem; }
#cta p { color: rgba(255,255,255,.6); max-width: 440px; }
.cta-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
 
@keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
#hero h1      { animation: fadeUp .65s .1s both; }
.hero-desc    { animation: fadeUp .65s .22s both; }
.hero-actions { animation: fadeUp .65s .34s both; }
.hero-right   { animation: fadeUp .65s .2s both; }
.card:nth-child(1) { animation: fadeUp .5s .08s both; }
.card:nth-child(2) { animation: fadeUp .5s .18s both; }
.card:nth-child(3) { animation: fadeUp .5s .28s both; }
</style>
</head>
<body>
 
<!-- HERO -->
<section id="hero">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <div class="hero-tag">AHA-Aligned Certification Training</div>
        <h1>Save a Life.<br>Start <em>Here.</em></h1>
        <p class="hero-desc">CPR Cart LLC delivers hands-on, American Heart Association–aligned certification courses for healthcare professionals and community members across United States.</p>
        <div class="hero-actions">
          <a class="btn btn-red" href="https://cprcart.com/">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
            Get CPR Certified
          </a>
          <a class="btn btn-ghost" href="https://cprcart.com/contact-us/">Contact for On-Site Training</a>
        </div>
      </div>
      <div class="hero-right">
        <div class="stat-card"><div class="stat-num">10k+</div><div class="stat-label">Professionals Certified</div></div>
        <div class="stat-card"><div class="stat-num">3</div><div class="stat-label">AHA-Aligned Courses</div></div>
        <div class="stat-card"><div class="stat-num">100%</div><div class="stat-label">Hands-On Training</div></div>
      </div>
    </div>
  </div>
  <svg class="ecg-wave" viewBox="0 0 1440 64" preserveAspectRatio="none" fill="none" height="64">
    <polyline points="0,32 180,32 220,8 248,56 276,8 304,56 332,32 580,32 620,16 660,48 700,16 740,48 780,32 1440,32"
      stroke="white" stroke-width="2" opacity="0.1"/>
  </svg>
</section>
 
<!-- TRUST BAR -->
<div id="trust">
  <div class="wrap">
    <div class="trust-row">
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        AHA-Aligned Curriculum
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        2-Year Certifications
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Group &amp; On-Site Available
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        Same-Day Card Issuance
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Serving United States
      </div>
    </div>
  </div>
</div>
 
<!-- ABOUT -->
<section id="about">
  <div class="wrap">
    <div class="about-grid">
      <div>
        <span class="eyebrow">Who We Are</span>
        <h2 class="section-title">Empowering Responders at Every Level</h2>
        <p style="font-size:1rem;color:var(--muted);line-height:1.7;">CPR Cart LLC was founded with a single mission: make life-saving skills accessible to everyone, from bedside nurses to front-desk staff to everyday community members. We deliver AHA HeartCode blended learning, combining self-paced online coursework with a quick, automated hands-on skills session at our training location.</p>
        <p style="font-size:1rem;color:var(--muted);line-height:1.7;margin-top:.85rem;">Skills checks are completed on advanced CPR manikins that provide real-time feedback and objective assessment, ensuring you meet the latest AHA guidelines. Every session is efficient, accurate, and designed to build confidence when seconds matter.</p>
        <ul class="check-list">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Fast, automated skills sessions with real-time feedback</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Attend your scheduled skills session at our training site</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Same-day certification cards upon successful completion</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Flexible scheduling including evenings and weekends</li>
        </ul>
        <a class="btn btn-red" href="https://cprcart.com/classes/">Explore Our Courses</a>
      </div>
      <div class="cert-grid">
        <div class="cert-card wide">
          <div class="cert-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg></div>
          <h3>AHA HeartCode Blended Learning</h3>
          <p>Complete online coursework at your own pace with a streamlined, in-person skills session</p>
        </div>
        <div class="cert-card">
          <div class="cert-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
          <h3>Flexible Scheduling</h3>
          <p>Choose a time that fits your schedule, including evenings and weekends</p>
        </div>
        <div class="cert-card">
          <div class="cert-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
          <h3>Fast Track Certification</h3>
          <p>Quick, efficient skills sessions designed to get you certified without long class hours</p>
        </div>
      </div>
    </div>
  </div>
</section>
 
<!-- CLASSES -->
<section id="classes">
  <div class="wrap">
    <div class="classes-head">
      <span class="eyebrow">Certification Courses</span>
      <h2 class="section-title">Choose Your Certification</h2>
      <p>We offer AHA HeartCode blended learning with flexible online modules and hands-on skills sessions, aligned with the latest AHA guidelines. Same-day certification cards issued.</p>
    </div>
 
    <div class="cards-grid">
 
      <!-- BLS -->
      <div class="card card--bls">
        <div class="card-stripe"></div>
        <div class="card-body">
          <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
          <div class="card-tag">Basic Life Support</div>
          <div class="card-title">BLS</div>
          <div class="card-subtitle">For Healthcare Providers</div>
          <p class="card-desc">The BLS course trains participants to promptly recognize cardiac arrest, perform high-quality CPR, use an AED effectively, and relieve choking in adults, children, and infants. Ideal for nurses, medical assistants, dental teams, and first responders.</p>
          <div class="pills">
            <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>30 min skills session</span>
            <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>All Skill Levels</span>
            <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>2-Yr Card</span>
          </div>
        </div>
        <div class="card-foot">
          <a href="https://cprcart.com/classes/bls/" class="card-btn">Enroll in BLS Class<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>
 
      <!-- ACLS -->
      <div class="card card--acls">
        <div class="card-stripe"></div>
        <div class="card-body">
          <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
          <div class="card-tag">Advanced Cardiovascular</div>
          <div class="card-title">ACLS</div>
          <div class="card-subtitle">Life Support — Provider Course</div>
          <p class="card-desc">ACLS builds on BLS skills to address complex cardiac emergencies. Participants master rhythm recognition, pharmacology, team dynamics, and management of stroke, acute coronary syndrome, and post-cardiac arrest care. Required for ICU, ED, and code-team personnel.</p>
          <div class="pills">
            <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>30 min skills session</span>
            <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>BLS Prereq</span>
            <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>2-Yr Card</span>
          </div>
        </div>
        <div class="card-foot">
          <a href="https://cprcart.com/classes/acls/" class="card-btn">Enroll in ACLS Class <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>
 
      <!-- PALS -->
      <div class="card card--pals">
        <div class="card-stripe"></div>
