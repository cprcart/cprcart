---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<style>
  /* ── Tokens ───────────────────────────────────────────────── */
  .cc-page {
    --cc-red:        #C8102E;
    --cc-red-dark:   #9B0C22;
    --cc-red-light:  #F4E6E9;
    --cc-navy:       #0D1B2A;
    --cc-navy-mid:   #1C2E40;
    --cc-silver:     #F5F6F8;
    --cc-muted:      #6B7280;
    --cc-text:       #1A1A2E;
    --cc-white:      #FFFFFF;
 
    --cc-font-display: 'Playfair Display', 'Georgia', serif;
    --cc-font-body:    'DM Sans', 'Helvetica Neue', sans-serif;
 
    --cc-radius:  12px;
    --cc-radius-lg: 24px;
    --cc-shadow:  0 4px 24px rgba(0,0,0,.08);
    --cc-shadow-lg: 0 16px 48px rgba(0,0,0,.14);
 
    font-family: var(--cc-font-body);
    color: var(--cc-text);
    line-height: 1.65;
  }
 
  /* ── Google Fonts ─────────────────────────────────────────── */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap');
 
  /* ── Shared utilities ─────────────────────────────────────── */
  .cc-page *,
  .cc-page *::before,
  .cc-page *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
  .cc-container {
    max-width: 1140px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }
 
  .cc-badge {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cc-red);
    background: var(--cc-red-light);
    padding: .35rem .85rem;
    border-radius: 999px;
    margin-bottom: 1.1rem;
  }
  .cc-badge svg { width: 14px; height: 14px; }
 
  /* ── ① HERO / INTRO ──────────────────────────────────────── */
  .cc-hero {
    position: relative;
    background: var(--cc-navy);
    overflow: hidden;
    padding: clamp(4rem, 10vw, 8rem) 0 clamp(5rem, 12vw, 10rem);
  }
 
  /* Diagonal red stripe accent */
  .cc-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg,
        var(--cc-red-dark) 0%,
        transparent 45%);
    opacity: .35;
    pointer-events: none;
  }
 
  /* ECG line decoration */
  .cc-hero-ecg {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 80px;
    opacity: .12;
    pointer-events: none;
  }
 
  .cc-hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
 
  @media (max-width: 768px) {
    .cc-hero-inner { grid-template-columns: 1fr; }
    .cc-hero-visual { display: none; }
  }
 
  .cc-hero-kicker {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--cc-red);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: .6rem;
  }
  .cc-hero-kicker::before {
    content: '';
    display: block;
    width: 28px;
    height: 2px;
    background: var(--cc-red);
  }
 
  .cc-hero h1 {
    font-family: var(--cc-font-display);
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    color: var(--cc-white);
    margin-bottom: 1.4rem;
  }
  .cc-hero h1 em {
    font-style: normal;
    color: var(--cc-red);
  }
 
  .cc-hero-desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,.72);
    max-width: 480px;
    margin-bottom: 2.2rem;
  }
 
  .cc-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
 
  .cc-btn {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .82rem 1.8rem;
    border-radius: var(--cc-radius);
    font-size: .95rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform .18s, box-shadow .18s, background .18s;
    text-decoration: none;
    border: none;
  }
  .cc-btn:hover { transform: translateY(-2px); }
 
  .cc-btn-primary {
    background: var(--cc-red);
    color: #fff;
    box-shadow: 0 6px 20px rgba(200,16,46,.4);
  }
  .cc-btn-primary:hover {
    background: var(--cc-red-dark);
    box-shadow: 0 10px 28px rgba(200,16,46,.5);
  }
 
  .cc-btn-outline {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,.35);
  }
  .cc-btn-outline:hover { border-color: #fff; background: rgba(255,255,255,.07); }
 
  /* Hero visual — stat cards */
  .cc-hero-visual {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }
 
  .cc-stat-card {
    background: rgba(255,255,255,.07);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--cc-radius-lg);
    padding: 1.4rem 2rem;
    text-align: center;
    min-width: 200px;
  }
  .cc-stat-card:nth-child(2) { margin-right: 2.5rem; }
 
  .cc-stat-num {
    font-family: var(--cc-font-display);
    font-size: 2.6rem;
    font-weight: 900;
    color: var(--cc-red);
    line-height: 1;
  }
  .cc-stat-label {
    font-size: .8rem;
    color: rgba(255,255,255,.6);
    margin-top: .3rem;
    text-transform: uppercase;
    letter-spacing: .1em;
  }
 
  /* ── ② TRUST BAR ─────────────────────────────────────────── */
  .cc-trust {
    background: var(--cc-white);
    border-bottom: 1px solid #E8EBF0;
    padding: 1.6rem 0;
  }
 
  .cc-trust-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem 3rem;
    align-items: center;
  }
 
  .cc-trust-item {
    display: flex;
    align-items: center;
    gap: .6rem;
    font-size: .88rem;
    font-weight: 500;
    color: var(--cc-muted);
  }
  .cc-trust-item svg {
    color: var(--cc-red);
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
 
  /* ── ③ ABOUT STRIP ───────────────────────────────────────── */
  .cc-about {
    padding: clamp(4rem, 8vw, 7rem) 0;
    background: var(--cc-silver);
  }
 
  .cc-about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  @media (max-width: 768px) { .cc-about-grid { grid-template-columns: 1fr; } }
 
  .cc-section-label {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--cc-red);
    margin-bottom: .8rem;
  }
 
  .cc-section-title {
    font-family: var(--cc-font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 900;
    line-height: 1.18;
    color: var(--cc-navy);
    margin-bottom: 1.3rem;
  }
 
  .cc-section-body {
    font-size: 1rem;
    color: var(--cc-muted);
    margin-bottom: 1.2rem;
  }
 
  .cc-check-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .75rem;
    margin-bottom: 2rem;
  }
  .cc-check-list li {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    font-size: .95rem;
    color: var(--cc-text);
  }
  .cc-check-list li svg {
    color: var(--cc-red);
    flex-shrink: 0;
    margin-top: .15rem;
    width: 18px;
    height: 18px;
  }
 
  /* About visual — cert logos grid */
  .cc-cert-visual {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }
 
  .cc-cert-box {
    background: var(--cc-white);
    border-radius: var(--cc-radius-lg);
    padding: 2rem 1.5rem;
    text-align: center;
    box-shadow: var(--cc-shadow);
    transition: transform .2s, box-shadow .2s;
  }
  .cc-cert-box:hover { transform: translateY(-4px); box-shadow: var(--cc-shadow-lg); }
  .cc-cert-box:first-child { grid-column: span 2; }
 
  .cc-cert-icon {
    width: 52px;
    height: 52px;
    background: var(--cc-red-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: var(--cc-red);
  }
  .cc-cert-icon svg { width: 26px; height: 26px; }
 
  .cc-cert-box h3 {
    font-family: var(--cc-font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--cc-navy);
    margin-bottom: .3rem;
  }
  .cc-cert-box p {
    font-size: .8rem;
    color: var(--cc-muted);
  }
 
  /* ── ④ CLASSES ───────────────────────────────────────────── */
  .cc-classes {
    padding: clamp(4rem, 8vw, 7rem) 0;
    background: var(--cc-white);
  }
 
  .cc-classes-head {
    text-align: center;
    max-width: 620px;
    margin: 0 auto 3.5rem;
  }
  .cc-classes-head .cc-section-label { display: block; }
  .cc-classes-head .cc-section-title { margin-bottom: .8rem; }
  .cc-classes-head p { color: var(--cc-muted); font-size: 1rem; }
 
  .cc-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.8rem;
  }
  @media (max-width: 900px) { .cc-cards { grid-template-columns: 1fr; max-width: 520px; margin-inline: auto; } }
 
  .cc-card {
    position: relative;
    border-radius: var(--cc-radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--cc-shadow);
    transition: transform .22s, box-shadow .22s;
    border: 1px solid #E8EBF0;
  }
  .cc-card:hover { transform: translateY(-6px); box-shadow: var(--cc-shadow-lg); }
 
  /* Card accent top bar */
  .cc-card-bar {
    height: 6px;
    width: 100%;
  }
  .cc-card--bls .cc-card-bar  { background: linear-gradient(90deg, #C8102E, #E8394D); }
  .cc-card--acls .cc-card-bar { background: linear-gradient(90deg, #0D1B2A, #1C3A5E); }
  .cc-card--pals .cc-card-bar { background: linear-gradient(90deg, #B8821A, #D4A02A); }
 
  .cc-card-body {
    padding: 2rem 1.8rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
 
  .cc-card-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: var(--cc-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.3rem;
  }
  .cc-card--bls  .cc-card-icon-wrap { background: var(--cc-red-light); color: var(--cc-red); }
  .cc-card--acls .cc-card-icon-wrap { background: #E6EBF0; color: var(--cc-navy); }
  .cc-card--pals .cc-card-icon-wrap { background: #FDF3E3; color: #B8821A; }
  .cc-card-icon-wrap svg { width: 28px; height: 28px; }
 
  .cc-card-tag {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    margin-bottom: .5rem;
  }
  .cc-card--bls  .cc-card-tag { color: var(--cc-red); }
  .cc-card--acls .cc-card-tag { color: var(--cc-navy); }
  .cc-card--pals .cc-card-tag { color: #B8821A; }
 
  .cc-card-title {
    font-family: var(--cc-font-display);
    font-size: 1.45rem;
    font-weight: 900;
    color: var(--cc-navy);
    margin-bottom: .3rem;
  }
  .cc-card-subtitle {
    font-size: .82rem;
    color: var(--cc-muted);
    margin-bottom: 1.1rem;
  }
  .cc-card-desc {
    font-size: .92rem;
    color: #4B5563;
    line-height: 1.65;
    margin-bottom: 1.5rem;
    flex: 1;
  }
 
  .cc-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: 1.6rem;
  }
  .cc-pill {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    padding: .3rem .8rem;
    border-radius: 999px;
    font-size: .75rem;
    font-weight: 500;
    background: var(--cc-silver);
    color: var(--cc-text);
  }
  .cc-pill svg { width: 12px; height: 12px; }
 
  .cc-card-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 1.8rem;
    background: var(--cc-silver);
    border-top: 1px solid #E8EBF0;
  }
 
  .cc-card-price {
    font-family: var(--cc-font-display);
    font-weight: 900;
    font-size: 1.5rem;
    color: var(--cc-navy);
  }
  .cc-card-price span {
    font-family: var(--cc-font-body);
    font-size: .78rem;
    font-weight: 500;
    color: var(--cc-muted);
    display: block;
    margin-top: -.15rem;
  }
 
  .cc-card-btn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .65rem 1.3rem;
    border-radius: var(--cc-radius);
    font-size: .85rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background .16s, transform .16s;
    border: none;
  }
  .cc-card-btn:hover { transform: translateX(2px); }
  .cc-card--bls  .cc-card-btn { background: var(--cc-red); color: #fff; }
  .cc-card--acls .cc-card-btn { background: var(--cc-navy); color: #fff; }
  .cc-card--pals .cc-card-btn { background: #B8821A; color: #fff; }
 
  /* ── ⑤ CTA STRIP ─────────────────────────────────────────── */
  .cc-cta {
    background: var(--cc-navy);
    padding: clamp(3.5rem, 8vw, 6rem) 0;
    position: relative;
    overflow: hidden;
  }
  .cc-cta::after {
    content: '';
    position: absolute;
    right: -120px;
    top: 50%;
    transform: translateY(-50%);
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,16,46,.22) 0%, transparent 70%);
    pointer-events: none;
  }
 
  .cc-cta-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
 
  .cc-cta h2 {
    font-family: var(--cc-font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 900;
    color: var(--cc-white);
    margin-bottom: .5rem;
  }
  .cc-cta p {
    color: rgba(255,255,255,.62);
    font-size: 1rem;
    max-width: 440px;
  }
  .cc-cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
 
  /* ── Animations ───────────────────────────────────────────── */
  @keyframes cc-fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0);    }
  }
 
  .cc-hero h1,
  .cc-hero-desc,
  .cc-hero-actions { animation: cc-fadeUp .7s ease both; }
  .cc-hero h1       { animation-delay: .1s; }
  .cc-hero-desc     { animation-delay: .22s; }
  .cc-hero-actions  { animation-delay: .34s; }
 
  .cc-card { animation: cc-fadeUp .55s ease both; }
  .cc-card:nth-child(1) { animation-delay: .08s; }
  .cc-card:nth-child(2) { animation-delay: .18s; }
  .cc-card:nth-child(3) { animation-delay: .28s; }
</style>
 
<!-- ══════════════════════════════════════════════════════════
     PAGE WRAPPER
══════════════════════════════════════════════════════════ -->
<div class="cc-page">
 
  <!-- ① HERO -->
  <section class="cc-hero">
    <!-- SVG ECG line -->
    <svg class="cc-hero-ecg" viewBox="0 0 1440 80" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polyline points="0,40 200,40 240,10 270,70 300,10 330,70 360,40 600,40 640,20 680,60 720,20 760,60 800,40 1440,40"
        stroke="white" stroke-width="2.5" fill="none"/>
    </svg>
 
    <div class="cc-container">
      <div class="cc-hero-inner">
        <!-- Left copy -->
        <div>
          <div class="cc-hero-kicker">AHA-Aligned Certification Training</div>
          <h1>Save a Life.<br>Start <em>Here.</em></h1>
          <p class="cc-hero-desc">
            CPR Cart LLC delivers hands-on, American Heart Association–aligned
            certification courses for healthcare professionals and community members.
            Learn BLS, ACLS, and PALS from expert instructors — on-site or at
            your location.
          </p>
          <div class="cc-hero-actions">
            <a class="cc-btn cc-btn-primary" href="#classes">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
              View Classes
            </a>
            <a class="cc-btn cc-btn-outline" href="#contact">
              Schedule On-Site Training
            </a>
          </div>
        </div>
 
        <!-- Right stats -->
        <div class="cc-hero-visual">
          <div class="cc-stat-card">
            <div class="cc-stat-num">10k+</div>
            <div class="cc-stat-label">Professionals Certified</div>
          </div>
          <div class="cc-stat-card">
            <div class="cc-stat-num">3</div>
            <div class="cc-stat-label">AHA-Aligned Courses</div>
          </div>
          <div class="cc-stat-card">
            <div class="cc-stat-num">100%</div>
            <div class="cc-stat-label">Hands-On Training</div>
          </div>
        </div>
      </div>
    </div>
  </section>
 
  <!-- ② TRUST BAR -->
  <div class="cc-trust">
    <div class="cc-container">
      <div class="cc-trust-inner">
        <div class="cc-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          AHA-Aligned Curricula
        </div>
        <div class="cc-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          2-Year Certifications
        </div>
        <div class="cc-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Group &amp; On-Site Available
        </div>
        <div class="cc-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.7a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.59 16l.33.92z"/></svg>
          Same-Day Card Issuance
        </div>
        <div class="cc-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Serving DFW &amp; Surrounding Areas
        </div>
      </div>
    </div>
  </div>
 
  <!-- ③ ABOUT / INTRO EXPANDED -->
  <section class="cc-about">
    <div class="cc-container">
      <div class="cc-about-grid">
        <div>
          <div class="cc-section-label">Who We Are</div>
          <h2 class="cc-section-title">Empowering Responders at Every Level</h2>
          <p class="cc-section-body">
            CPR Cart LLC was founded with a single mission: make life-saving skills
            accessible to everyone — from bedside nurses to front-desk staff to
            everyday community members. We bring AHA-aligned certification training
            directly to hospitals, clinics, businesses, and schools across the DFW
            metroplex.
          </p>
          <p class="cc-section-body">
            Our certified instructors combine real-world clinical experience with
            engaging, scenario-based teaching. Every class is hands-on, outcome-focused,
            and designed to build the confidence you need when seconds count.
          </p>
          <ul class="cc-check-list">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Small class sizes for maximum skill retention
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              We travel to your facility — zero disruption to your schedule
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Certification cards issued the same day of class completion
            </li>
            <li>
