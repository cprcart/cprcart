---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			---
// Astro Frontmatter (if needed for data fetching)
---

<!-- Hero Section -->
<section class="hero-bg grid-pattern min-h-screen flex items-center pt-8 sm:pt-12 relative overflow-hidden">
    <!-- Background decorations -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="float absolute top-1/4 left-10 w-64 h-64 bg-teal-500/10 rounded-full blur-3xl"></div>
        <div class="float-delayed absolute bottom-1/4 right-10 w-80 h-80 bg-accent/10 rounded-full blur-3xl"></div>
        
        <!-- Animated Pulse Line -->
        <svg class="absolute top-1/2 left-0 w-full h-32 opacity-20" viewBox="0 0 1200 100" preserveAspectRatio="none">
            <path class="pulse-line" d="M0,50 L200,50 L220,50 L240,20 L260,80 L280,30 L300,70 L320,50 L400,50 L600,50 L620,50 L640,15 L660,85 L680,25 L700,75 L720,50 L900,50 L920,50 L940,10 L960,90 L980,20 L1000,80 L1020,50 L1200,50" fill="none" stroke="url(#pulseGradient)" stroke-width="2"/>
            <defs>
                <linearGradient id="pulseGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#4fd1c5" stop-opacity="0"/>
                    <stop offset="50%" stop-color="#4fd1c5" stop-opacity="1"/>
                    <stop offset="100%" stop-color="#4fd1c5" stop-opacity="0"/>
                </linearGradient>
            </defs>
        </svg>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <!-- Left: Content -->
            <div class="text-center lg:text-left">
                <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full bg-teal-500/10 border border-teal-500/20 mb-6">
                    <span class="w-2 h-2 rounded-full bg-teal-400 animate-pulse"></span>
                    <span class="text-teal-400 text-sm font-medium">American Heart Association Certified</span>
                </div>

                <h1 class="reveal reveal-delay-1 font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-tight mb-6">
                    <span class="text-fg">Confidence to</span><br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-400 to-teal-500">Save Lives</span>
                </h1>

                <p class="reveal reveal-delay-2 text-muted text-lg sm:text-xl max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
                    Professional CPR certification training for healthcare providers and individuals. Learn life-saving skills from certified instructors in a supportive environment.
                </p>

                <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                    <a href="#classes" class="btn-primary px-8 py-4 rounded-xl font-display font-semibold text-white text-center">
                        View Classes
                    </a>
                    <a href="#" class="btn-secondary px-8 py-4 rounded-xl font-display font-semibold text-fg text-center">
                        Contact Us
                    </a>
                </div>

                <div class="reveal reveal-delay-4 mt-12 pt-8 border-t border-border">
                    <div class="flex flex-wrap justify-center lg:justify-start gap-8">
                        <div class="text-center">
                            <div class="stat-number font-display font-bold text-2xl sm:text-3xl text-fg">15K+</div>
                            <div class="text-muted text-sm">Certified Students</div>
                        </div>
                        <div class="text-center">
                            <div class="stat-number font-display font-bold text-2xl sm:text-3xl text-fg">98%</div>
                            <div class="text-muted text-sm">Pass Rate</div>
                        </div>
                        <div class="text-center">
                            <div class="stat-number font-display font-bold text-2xl sm:text-3xl text-fg">10+</div>
                            <div class="text-muted text-sm">Years Experience</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Hero visual -->
            <div class="reveal reveal-delay-2 relative hidden lg:block">
                <div class="relative">
                    <div class="bg-card/80 backdrop-blur-sm rounded-3xl border border-border p-8 relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-48 h-48 bg-teal-500/10 rounded-full blur-3xl"></div>
                        
                        <div class="relative z-10">
                            <div class="flex items-center gap-4 mb-6">
                                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal-400/20 to-teal-600/20 flex items-center justify-center">
                                    <svg class="w-8 h-8 text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="font-display font-bold text-xl text-fg">CPR Certification</h3>
                                    <p class="text-muted text-sm">AHA Approved Course</p>
                                </div>
                            </div>

                            <div class="space-y-4 mb-6">
                                <div class="flex items-center gap-3">
                                    <svg class="w-5 h-5 text-teal-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m5 13 4 4L19 7"/>
                                    </svg>
                                    <span class="text-fg text-sm">Same-day certification card</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <svg class="w-5 h-5 text-teal-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m5 13 4 4L19 7"/>
                                    </svg>
                                    <span class="text-fg text-sm">Hands-on practice with manikins</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <svg class="w-5 h-5 text-teal-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m5 13 4 4L19 7"/>
                                    </svg>
                                    <span class="text-fg text-sm">2-year certification validity</span>
                                </div>
                            </div>

                            <div class="flex items-center justify-between pt-4 border-t border-border">
                                <div>
                                    <span class="text-muted text-sm">Starting at</span>
                                    <div class="font-display font-bold text-2xl text-fg">$65</div>
                                </div>
                                <button class="btn-primary px-6 py-3 rounded-xl font-display font-semibold text-white text-sm">
                                    Enroll Now
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="absolute -bottom-4 -left-4 bg-accent rounded-2xl px-5 py-3 shadow-lg badge-glow float">
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <span class="text-white font-display font-semibold text-sm">Flexible Scheduling</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Classes Section -->
<section id="classes" class="py-20 sm:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-bg via-card to-bg" aria-hidden="true"></div>
    <div class="absolute inset-0 grid-pattern opacity-50" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16 sm:mb-20">
            <span class="reveal inline-block text-teal-400 font-display font-semibold text-sm uppercase tracking-wider mb-4">
                Our Courses
            </span>
            <h2 class="reveal reveal-delay-1 font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl text-fg mb-6">
                Certification Classes
            </h2>
            <p class="reveal reveal-delay-2 text-muted text-lg max-w-2xl mx-auto">
                Choose from our comprehensive selection of American Heart Association certification courses designed for healthcare professionals and individuals.
            </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            <!-- BLS Card -->
            <article class="reveal reveal-delay-1 class-card relative bg-card/80 backdrop-blur-sm rounded-2xl border border-border p-6 sm:p-8 overflow-hidden group">
                <div class="relative z-10">
                    <div class="icon-container w-16 h-16 rounded-2xl flex items-center justify-center mb-6">
                        <svg class="w-8 h-8 text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                            <path d="M12 5v3m0 0v3m0-3h3m-3 0H9"/>
                        </svg>
                    </div>

                    <div class="flex items-start justify-between gap-4 mb-4">
                        <h3 class="font-display font-bold text-xl sm:text-2xl text-fg">
                            Basic Life Support
                        </h3>
                        <span class="flex-shrink-0 px-3 py-1 rounded-full bg-teal-500/10 border border-teal-500/20 text-teal-400 text-xs font-semibold">
                            BLS
                        </span>
                    </div>

                    <p class="text-muted mb-6 leading-relaxed">
                        Foundational CPR training for healthcare providers. Learn high-quality CPR, AED use, and relief of choking for adults, children, and infants.
                    </p>

                    <div class="space-y-3 mb-6">
                        <div class="flex items-center gap-3 text-sm">
                            <svg class="w-4 h-4 text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <span class="text-muted">Duration: <span class="text-fg">4-4.5 hours</span></span>
                        </div>
                        <div class="flex items-center gap-3 text-sm">
                            <svg class="w-4 h-4 text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <span class="text-muted">Certification: <span class="text-fg">2 years</span></span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between pt-6 border-t border-border">
                        <div>
                            <span class="text-muted text-sm">Starting at</span>
                            <div class="font-display font-bold text-2xl text-fg">$65</div>
                        </div>
                        <a href="#" class="btn-primary px-5 py-2.5 rounded-xl font-display font-semibold text-white text-sm">
                            Enroll Now
                        </a>
                    </div>
                </div>
            </article>

            <!-- ACLS Card -->
            <article class="reveal reveal-delay-2 class-card relative bg-card/80 backdrop-blur-sm rounded-2xl border border-border p-6 sm:p-8 overflow-hidden group">
                <div class="absolute top-4 right-4 px-3 py-1 rounded-full bg-accent/20 border border-accent/30 text-accent text-xs font-semibold">
                    Most Popular
                </div>

                <div class="relative z-10">
                    <div class="icon-container w-16 h-16 rounded-2xl flex items-center justify-center mb-6">
                        <svg class="w-8 h-8 text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                        </svg>
                    </div>

                    <div class="flex items-start justify-between gap-4 mb-4">
                        <h3 class="font-display font-bold text-xl sm:text-2xl text-fg">
                            Advanced Cardiovascular Life Support
                        </h3>
                        <span class="flex-shrink-0 px-3 py-1 rounded-full bg-teal-500/10 border border-teal-500/20 text-teal-400 text-xs font-semibold">
                            ACLS
                        </span>
                    </div>

                    <p class="text-muted mb-6 leading-relaxed">
                        Advanced training for managing cardiovascular emergencies. Includes airway management, pharmacology, and team dynamics during resuscitation.
                    </p>

                    <div class="space-y-3 mb-6">
                        <div class="flex items-center gap-3 text-sm">
                            <svg class="w-4 h-4 text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <span class="text-muted">Duration: <span class="text-fg">12-16 hours</span></span>
                        </div>
                        <div class="flex items-center gap-3 text-sm">
                            <svg class="w-4 h-4 text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <span class="text-muted">Certification: <span class="text-fg">2 years</span></span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between pt-6 border-t border-border">
                        <div>
                            <span class="text-muted text-sm">Starting at</span>
                            <div class="font-display font-bold text-2xl text-fg">$200</div>
                        </div>
                        <a href="#" class="btn-primary px-5 py-2.5 rounded-xl font-display font-semibold text-white text-sm">
                            Enroll Now
                        </a>
                    </div>
                </div>
            </article>

            <!-- PALS Card -->
            <article class="reveal reveal-delay-3 class-card relative bg-card/80 backdrop-blur-sm rounded-2xl border border-border p-6 sm:p-8 overflow-hidden group">
                <div class="relative z-10">
                    <div class="icon-container w-16 h-16 rounded-2xl flex items-center justify-center mb-6">
                        <svg class="w-8 h-8 text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 6v6l4 2"/>
                        </svg>
                    </div>

                    <div class="flex items-start justify-between gap-4 mb-4">
                        <h3 class="font-display font-bold text-xl sm:text-2xl text-fg">
                            Pediatric Advanced Life Support
                        </h3>
                        <span class="flex-shrink-0 px-3 py-1 rounded-full bg-teal-500/10 border border-teal-500/20 text-teal-400 text-xs font-semibold">
                            PALS
                        </span>
                    </div>

                    <p class="text-muted mb-6 leading-relaxed">
                        Specialized training for pediatric emergencies. Learn to recognize and manage respiratory distress, shock, and arrhythmias in infants and children.
                    </p>

                    <div class="space-y-3 mb-6">
                        <div class="flex items-center gap-3 text-sm">
                            <svg class="w-4 h-4 text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <span class="text-muted">Duration: <span class="text-fg">14-16 hours</span></span>
                        </div>
                        <div class="flex items-center gap-3 text-sm">
                            <svg class="w-4 h-4 text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <span class="text-muted">Certification: <span class="text-fg">2 years</span></span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between pt-6 border-t border-border">
                        <div>
                            <span class="text-muted text-sm">Starting at</span>
                            <div class="font-display font-bold text-2xl text-fg">$225</div>
                        </div>
                        <a href="#" class="btn-primary px-5 py-2.5 rounded-xl font-display font-semibold text-white text-sm">
                            Enroll Now
                        </a>
                    </div>
                </div>
            </article>
        </div>

        <div class="reveal mt-16 text-center">
            <p class="text-muted mb-6">
                Not sure which course is right for you?
            </p>
            <a href="#" class="btn-secondary inline-flex items-center gap-2 px-6 py-3 rounded-xl font-display font-semibold text-fg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 0 1-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8Z"/>
                </svg>
                Talk to an Advisor
            </a>
        </div>
    </div>
</section>

<style>
    /* CSS Variables - Map to Tailwind config or keep here for global use */
    :root {
        --bg: #0a0f0d;
        --fg: #f4f7f5;
        --muted: #7a8a82;
        --accent: #e85d4c;
        --card: #141c18;
        --border: #2a3830;
        --teal: #4fd1c5;
    }

    /* Custom Utilities */
    .hero-bg {
        background: 
            radial-gradient(ellipse 80% 50% at 50% -20%, rgba(79, 209, 197, 0.15), transparent),
            radial-gradient(ellipse 60% 40% at 80% 60%, rgba(232, 93, 76, 0.08), transparent),
            linear-gradient(180deg, var(--bg) 0%, #0d1410 100%);
    }

    .grid-pattern {
        background-image: 
            linear-gradient(rgba(79, 209, 197, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(79, 209, 197, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
    }

    .stat-number { font-variant-numeric: tabular-nums; }

    /* Animations */
    .pulse-line {
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
        animation: pulseDraw 3s ease-in-out infinite;
    }

    @keyframes pulseDraw {
        0%, 100% { stroke-dashoffset: 1000; opacity: 0.3; }
        50% { stroke-dashoffset: 0; opacity: 1; }
    }

    .float { animation: float 6s ease-in-out infinite; }
    .float-delayed { animation: float 6s ease-in-out 2s infinite; }

    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
    }

    /* Reveal Animation Logic */
    .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* Card & Button Styles */
    .class-card {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        transform-origin: center;
    }
    .class-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 25px 50px -12px rgba(79, 209, 197, 0.15);
    }
    .class-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1px;
        background: linear-gradient(135deg, rgba(79, 209, 197, 0.3), transparent 50%, rgba(232, 93, 76, 0.2));
        mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        mask-composite: xor;
        -webkit-mask-composite: xor;
        opacity: 0;
        transition: opacity 0.4s ease;
    }
    .class-card:hover::before { opacity: 1; }

    .icon-container {
        background: linear-gradient(135deg, rgba(79, 209, 197, 0.15), rgba(79, 209, 197, 0.05));
        transition: all 0.3s ease;
    }
    .class-card:hover .icon-container {
        background: linear-gradient(135deg, rgba(79, 209, 197, 0.25), rgba(79, 209, 197, 0.1));
        transform: scale(1.1);
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--accent), #d14a3a);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    .btn-primary::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px -5px rgba(232, 93, 76, 0.4);
    }
    .btn-primary:hover::after { opacity: 1; }

    .btn-secondary {
        border: 1px solid var(--border);
        transition: all 0.3s ease;
    }
    .btn-secondary:hover {
        border-color: var(--teal);
        background: rgba(79, 209, 197, 0.1);
    }

    .badge-glow { box-shadow: 0 0 20px rgba(79, 209, 197, 0.3); }

    /* Reduced Motion */
    @media (prefers-reduced-motion: reduce) {
        .reveal, .class-card, .btn-primary, .btn-secondary, .float, .float-delayed, .pulse-line {
            animation: none;
            transition: none;
        }
        .reveal { opacity: 1; transform: none; }
    }
</style>

<script>
    // Intersection Observer for scroll reveal
    document.addEventListener('DOMContentLoaded', () => {
        const reveals = document.querySelectorAll('.reveal');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, { threshold: 0.1 });

        reveals.forEach(el => observer.observe(el));
    });
</script>
		</main>
		<Footer />
	</body>
</html>
